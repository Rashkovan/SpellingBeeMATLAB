%% WORD validation 
function [isValid, message] = validateWord(word, centerLetter, availableLetters, wordList, themeWords, usedWords)
  % VALIDATEWORD  Validates a player's submitted word.
  %
  % INPUTS:
  %   word: the word the player typed
  %   centerLetter: the mandatory center letter (1 char)
  %   availableLetters: all 7 allowed letters, e.g. 'smtareh'
  %   wordList: full dictionary of valid words
  %   themeWords: subset matching the theme
  %   usedWords: words already found this game
  % OUTPUTS:
  %   isValid: true only if ALL checks pass
  %   message:  feedback shown to the player

      word             = lower(strtrim(word));
      centerLetter     = lower(centerLetter(1));
      availableLetters = lower(availableLetters);

      isValid = false;

      % Minimum length (>= 4 letters)
      if length(word) < 4
          message = 'Too short! Words must be at least 4 letters.';
          return;
      end

      % Must contain the center letter A
      if ~any(word == centerLetter)
          message = sprintf('Must use the center letter "%s"!', upper(centerLetter));
          return;
      end

      % Every letter must be from the available set (reuse allowed)
      [lettersOK, badLetter] = checkLettersAllowed(word, availableLetters);
      if ~lettersOK
          message = sprintf('"%s" is not one of your letters!', upper(badLetter));
          return;
      end

      % Word not already used this game
      if ismember(word, usedWords)
          message = 'Already found that one!';
          return;
      end

      % Must be a real word
      if ~ismember(word, wordList)
          message = 'Not a recognized word.';
          return;
      end

      % Must match the theme
      if ~ismember(word, themeWords)
          message = 'Doesn''t fit the theme — try again!';
          return;
      end

      isValid = true;
      message = 'Nice word!';
  end

  % checkLettersAllowed — Letter Reuse Logic
  % key helper. every letter in the word must appear somewhere in the 7-letter set,
  % letter can be used more than once.

allAllowed     = true;
      firstBadLetter = '';

      for i = 1:length(word)
          letter = word(i);
          if ~ismember(letter, availableLetters)
              allAllowed     = false;
              firstBadLetter = letter;
              return;
          end
      end
  end

  %% HAMSTER puzzle 
  % Letters : S M T A R E H
  % Center  : A (mandatory)
  % Rule    : minimum 4 letters, word must contain A, only use SMTAREH
  %
  % OUTPUT:
  %   puzzle.availableLetters  smtareh'
  %   puzzle.centerLetter     'a'
  %   puzzle.pangram    'hamster'
  %   puzzle.themeWords        - cell array of all valid words
  %   puzzle.wordPoints        - containers.Map of word -> point value

function [allAllowed, firstBadLetter] = checkLettersAllowed(word, availableLetters)
 puzzle.availableLetters = 'smtareh';
      puzzle.centerLetter     = 'a';
      puzzle.pangram          = 'hamster';
% excluded words: 
% - sub-4 letters
% - no central A 

% 4 letter words 
fourLetters = { ...
          'ears',  'east',  'eats',  'eras', ...
          'hams',  'hare',  'hart',  'hate', ...
          'hats',  'hear',  'heat',  'mare', ...
          'mars',  'mart',  'mash',  'mast', ...
          'math',  'mate',  'meat',  'rame', ...
          'rash',  'rate',  'rats',  'rhea', ...
          'same',  'seam',  'sear',  'seat', ...
          'star',  'tame',  'team',  'tear' ...
      };
% 5-letter words
 fiveLetters = { ...
          'earth',  'harem',  'harts',  'hater', ...
          'hates',  'hears',  'heart',  'heats', ...
          'mares',  'maths',  'mater',  'mates', ...
          'meats',  'ramet',  'rates',  'rheas', ...
          'share',  'shear',  'smart',  'smear', ...
          'stare',  'steam',  'tamer',  'tames', ...
          'teams'  ...
      };
% 6-letter words 
sixLetters = { ...
          'earths',  'harems',  'haters',  'hearts', ...
          'maters',  'ramets',  'stream',  'tamers' , 'master'...
      };
% 7-letter words 
  sevenLetters = { ...
          'hamster',  'mathers',  ...
      };
   puzzle.themeWords = [ ...
          fourLetters, fiveLetters, sixLetters, sevenLetters ...
      ];



      allAllowed     = true;
      firstBadLetter = '';

      for i = 1:length(word)
          letter = word(i);

          %% allows the same letter to appear multiple times in word
          if ~ismember(letter, availableLetters)
              allAllowed     = false;
              firstBadLetter = letter;
              return;                  % stop at first bad letter
          end
      end
  end 
