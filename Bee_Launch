%%  UI REFRESH HELPERS

%% Win or loss summary

%% RESTART GAME 
function restartGame(fig, dlg)
    % Wipe state and redraw — same as a fresh SpellingBee() call.
        close(dlg);
        initState(fig);
        ax = findobj(fig, 'Tag', 'AxesHex');
        cla(ax);
        drawHexGrid(fig);
        drawBee(fig);
        gs = getGameState(fig);
        refreshScore(fig, gs);
        refreshWordList(fig, gs);
        findobj(fig,'Tag','FieldWord').Value     = '';
        findobj(fig,'Tag','LblFeedback').Text    = '';
        findobj(fig,'Tag','LblPenalty').Text     = 'Penalties: 0 / 5';
        findobj(fig,'Tag','LblBeeStatus').Text   = 'Your bee is thriving!';
    end
 
end  
